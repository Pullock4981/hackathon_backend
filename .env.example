PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?appName=Cluster0
JWT_SECRET=your_jwt_secret_key
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Email Configuration (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=YOUR_EMAIL_HERE@gmail.com
SMTP_PASS=your_16_digit_app_password
FROM_EMAIL="Hackathon Admin <YOUR_EMAIL_HERE@gmail.com>"

# AI Configuration
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
